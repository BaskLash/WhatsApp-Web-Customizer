{
  "manifest_version": 3,
  "name": "WhatsApp Web Customizer – Themes, Fonts, Backgrounds & Quick Reply Bubbles",
  "version": "1.1.1",
  "description": "Personalize WhatsApp Web with themes, fonts, backgrounds, and fast-reply tools. Lightweight, clean, and fully open source.",
  "permissions": ["storage", "scripting", "clipboardRead", "alarms"],
  "optional_host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WhatsApp Web Customizer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icon/icon16.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/"],
      "js": [
        "track.js",
        "fontFamilyChange.js",
        "changeContent.js",
        "quick-reply-bubbles.js",
        "themes-presets.js",
        "themes-content.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://web.whatsapp.com/",
    "https://eu.i.posthog.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["themes-overrides.css"],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ]
}
