{
  "manifest_version": 3,
  "name": "WhatsApp Web Customizer – Themes, Fonts, Backgrounds & Quick Reply Bubbles",
  "version": "1.0.12",
  "description": "Personalize WhatsApp Web with themes, fonts, backgrounds, and fast-reply tools. Lightweight, clean, and fully open source.",
  "permissions": ["storage", "scripting", "clipboardRead"],
  "optional_host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WhatsApp Web Customizer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon/icon16.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/"],
      "js": [
        "fontFamilyChange.js",
        "changeContent.js",
        "quick-reply-bubbles.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["https://web.whatsapp.com/"]
}
